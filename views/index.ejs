<main class="container">
    <section class="welcome">
        <h2>Welcome to CSE Motors!</h2>
        <div class="featured-car">
            <img src="/images/vehicles/delorean.jpg" alt="DMC Delorean" class="car-image">
            <div class="car-details">
                <h3>DMC Delorean</h3>
                <ul>
                    <li>3 Cup holders</li>
                    <li>Superman doors</li>
                    <li>Fuzzy dice!</li>
                </ul>
                <button>Own Today</button>
            </div>
        </div>
    </section>
    <aside class="upgrades-reviews">
        <section class="upgrades">
            <h3>Delorean Upgrades</h3>
            <div class="updates-grid">
                <div class="upgrade-item">
                    <img src="/images/upgrades/flux-cap.png" alt="Flux Capacitor" class="upgrade-image">
                    <span>Flux Capacitor</span>
                </div>
                <div class="upgrade-item">
                    <img src="/images/upgrades/flame.jpg" alt="Flame Decals" class="upgrade-image">
                    <span>Flame Decals</span>
                </div>
                <div class="upgrade-item">
                    <img src="/images/upgrades/bumper_sticker.jpg" alt="Bumper Sticker" class="upgrade-image">
                    <span>Bumper Sticker</span>
                </div>
                <div class="upgrade-item">
                    <img src="/images/upgrades/hub-cap.jpg" alt="Hub Caps" class="upgrade-image">
                    <span>Hub Caps</span>
                </div>
            </div>
        </section>
        <section class="reviews">
            <h3>DMC Delorean Reviews</h3>
            <ul>
                <li>"So fast it's almost like traveling in time." (4/5)"</li>
                <li>"Coolest ride on the road!" (5/5)</li>
                <li>"I love the retro look!" (4/5)</li>
                <li>"Great for time travel simulations." (4.5/5)</li>
                <li>"The best Delorean ever made!" (5/5)</li>
            </ul>
        </section>
    </aside>
</main>
